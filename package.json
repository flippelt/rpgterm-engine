  "license": "MIT",
  "author": "Felipe Lippelt",
  "keywords": ["terminal", "ttrpg", "rpg", "tabletop", "engine", "hacking"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippelt/rpgterm-engine.git"
  },
  "homepage": "https://github.com/flippelt/rpgterm-engine#readme",
  "bugs": "https://github.com/flippelt/rpgterm-engine/issues",
  "files": ["src", "!src/**/*.test.js"],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "vitest": "^4.1.8"
  }
